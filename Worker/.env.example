WORKER_HOST=0.0.0.0
WORKER_PORT=8080
WORKER_LOG_LEVEL=info
WORKER_NAME=optimizer-1

# Benchmark store (relative to Worker/)
WORKER_DATA_DIR=datasets
WORKER_CHROMOSOMES=chr20,chr21

# Benchmark mode (recommended): optimize on fixed HG002 benchmark BAM + GIAB truth.
# Only the job window (region) comes from the live Minos round — no platform BAM download.
WORKER_BENCHMARK_MODE=true
WORKER_BENCHMARK_TRUTH_VCF=data/HG002_GRCh38_1_22_v4.2.1_benchmark.vcf.gz
WORKER_DOWNLOAD_BAM=false
WORKER_DOWNLOAD_SDF=true
WORKER_TOOLS=gatk,bcftools,deepvariant

# Benchmark BAM for chr20 + chr21 (not platform round BAM). Sources:
#   datasets/bam/HG002_chr{N}_minos_window.bam  (legacy local)
#   WORKER_BENCHMARK_HF_REPO  (HuggingFace dataset)
#   WORKER_BENCHMARK_BAM_URLS=chr20:https://...,chr21:https://...
WORKER_BENCHMARK_HF_REPO=TerryStewart/minos

# Split tune params across parallel lanes when concurrency > 1 (faster; not full grid).
WORKER_PARAM_SPLIT_CONCURRENCY=true

# Speedups: cache scored VCFs per config; keep GATK containers warm per job.
WORKER_VCF_CACHE_ENABLED=true
WORKER_VCF_CACHE_DIR=vcf_cache
WORKER_GATK_PERSISTENT_CONTAINER=true

# random / optuna: trials after base benchmark (grid uses full search space instead).
WORKER_ADAPTIVE_MAX_TRIALS=30

# Faster benchmark: center-crop live round to N Mb (2 = 2M inside 5M round).
WORKER_BENCHMARK_SUBWINDOW_MB=2

# Per concurrent trial slot (GATK Docker --cpus / --memory).
WORKER_TRIAL_THREADS=4
WORKER_TRIAL_MEMORY_GB=7

# Installed by setup: datasets/bams/chr20.bam  datasets/bams/chr21.bam
# GIAB truth: datasets/data/HG002_GRCh38_1_22_v4.2.1_benchmark.vcf.gz

# Platform round BAM download (only when WORKER_BENCHMARK_MODE=false):
# WORKER_DOWNLOAD_BAM=true
# WORKER_BAM_URLS=chr21:https://...

# Path to minos_subnet checkout (defaults to parent of Worker/)
# WORKER_REPO_ROOT=/path/to/minos_subnet

# Platform API (only needed when downloading platform BAM/truth)
WORKER_PLATFORM_URL=https://api.theminos.ai
WORKER_REFERENCE_URL=https://api.theminos.ai/reference
