WORKER_HOST=0.0.0.0
WORKER_PORT=8080
WORKER_LOG_LEVEL=info
WORKER_NAME=optimizer-1

# All benchmark data lives under Worker/datasets/
WORKER_DATA_DIR=datasets
WORKER_CHROMOSOMES=chr20,chr21

# Adaptive search: optuna, gp, random, sobol, lhs (see WORKER_ADAPTIVE_MAX_TRIALS).
WORKER_ADAPTIVE_MAX_TRIALS=30

# Faster benchmark: random N Mb slice inside dispatched round (3 = 3M inside 5M round).
WORKER_BENCHMARK_SUBWINDOW_MB=3

# Per concurrent trial slot (GATK Docker --cpus / --memory).
WORKER_TRIAL_THREADS=4
WORKER_TRIAL_MEMORY_GB=7

# Layout (created by setup / first benchmark):
#   datasets/reference/{chr}/{chr}.fa + .fai + .sdf
#   datasets/giab/data/   — GIAB truth VCF + confident BED
#   datasets/giab/bam/    — regional HG002 BAM slices
#   datasets/giab/vcf/    — scored VCF reuse cache

# Path to minos_subnet checkout (templates + scoring). Default: parent of Worker/
# WORKER_REPO_ROOT=/path/to/minos_subnet

WORKER_PLATFORM_URL=https://api.theminos.ai
WORKER_REFERENCE_URL=https://api.theminos.ai/reference
