MAIN_DATABASE_URL=sqlite+aiosqlite:///./main.db
# If you imported history into fish.db instead, use:
# MAIN_DATABASE_URL=sqlite+aiosqlite:///./fish.db
MAIN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAIN_API_PREFIX=/api/v1

# Platform round polling (Minos API)
MAIN_PLATFORM_ENABLED=true
MAIN_PLATFORM_URL=https://api.theminos.ai
MAIN_PLATFORM_TIMEOUT=60
MAIN_PLATFORM_POLL_SECONDS=10
# Demo mode: use /v2/demo/round-status with ephemeral keypair (no wallet)
MAIN_PLATFORM_DEMO_MODE=true
# Live mode: set MAIN_PLATFORM_DEMO_MODE=false and your miner hotkey URI below
# MAIN_PLATFORM_WALLET_URI=//your-miner-seed-or-mnemonic

# Minos tuning exports (auto-import when history DB is empty)
# Defaults resolve to <repo>/instances/*/tuning/data/round_history.json
# MAIN_HISTORY_JSON_PATHS=C:\minos\instances\gatk\tuning\data\round_history.json

# Portfolio rounds API — merged into round_history on startup and via POST /api/v1/history/sync-rounds
MAIN_HISTORY_API_URL=http://192.168.131.16:7860/api/rounds
MAIN_HISTORY_API_SYNC_ON_STARTUP=true
MAIN_HISTORY_API_TIMEOUT=4320

# Worker chr22 seed sync (GET /seed/results every 30 min → round_history)
MAIN_SEED_RESULTS_POLL_ENABLED=true
MAIN_SEED_RESULTS_POLL_SECONDS=1800
